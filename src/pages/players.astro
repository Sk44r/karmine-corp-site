---
import BaseLayout from "../layouts/BaseLayout.astro";
import players from "../data/players.json";

const playersByGame = players.reduce((groups, player) => {
  const game = player.game || "Autre";

  if (!groups[game]) {
    groups[game] = [];
  }

  groups[game].push(player);

  return groups;
}, {});

const games = Object.keys(playersByGame);
---

<BaseLayout title="Joueurs | Blue Vault">
  <section class="page-header">
    <p class="eyebrow">Effectifs</p>
    <h1>Joueurs</h1>
    <p>
      Liste des joueurs renseignés dans la base, regroupés par jeu.
    </p>
  </section>

  <section class="stats">
    <div>
      <strong>{players.length}</strong>
      <span>joueurs renseignés</span>
    </div>

    <div>
      <strong>{games.length}</strong>
      <span>jeux représentés</span>
    </div>
  </section>

  <nav class="game-nav">
    {games.map((game) => (
      <a href={`#${game.toLowerCase().replaceAll(" ", "-")}`}>
        {game}
      </a>
    ))}
  </nav>

  {games.map((game) => (
    <section class="game-section" id={game.toLowerCase().replaceAll(" ", "-")}>
      <h2>{game}</h2>

      <div class="player-grid">
        {playersByGame[game].map((player) => (
          <article class="player-card">
            <div class="player-topline">
              <h3>{player.nickname}</h3>
              <span>{player.status}</span>
            </div>

            <p class="name">
              {player.firstName} {player.lastName}
            </p>

            <p class="details">
              {player.countryCode ? `${player.countryCode} — ` : ""}
              {player.country}
            </p>

            <p class="details">
              {player.teamName} — {player.role}
            </p>

            {player.socialUrl && (
              <a href={player.socialUrl} target="_blank" rel="noreferrer">
                Réseau / profil
              </a>
            )}
          </article>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 32px;
  }

  .eyebrow {
    color: #60a5fa;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 13px;
    font-weight: bold;
  }

  h1 {
    font-size: 48px;
    margin: 12px 0;
  }

  .page-header p {
    max-width: 700px;
    color: #cbd5e1;
    font-size: 18px;
    line-height: 1.6;
  }

  .stats {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .stats div {
    padding: 18px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .stats strong {
    display: block;
    font-size: 32px;
  }

  .stats span {
    color: #cbd5e1;
  }

  .game-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 40px;
  }

  .game-nav a {
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(37, 99, 235, 0.22);
    color: #bfdbfe;
    text-decoration: none;
  }

  .game-section {
    margin-top: 48px;
  }

  h2 {
    color: #93c5fd;
    font-size: 30px;
  }

  .player-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }

  .player-card {
    padding: 20px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .player-topline {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
  }

  h3 {
    margin: 0 0 8px;
    font-size: 26px;
  }

  .player-topline span {
    padding: 5px 9px;
    border-radius: 999px;
    background: rgba(37, 99, 235, 0.25);
    color: #bfdbfe;
    font-size: 13px;
  }

  .name {
    color: #e5e7eb;
  }

  .details {
    color: #cbd5e1;
  }

  a {
    color: #93c5fd;
  }
</style>
---
import BaseLayout from "../layouts/BaseLayout.astro";
import results from "../data/results.json";
import players from "../data/players.json";

const latestResults = [...results]
  .sort((a, b) => new Date(b.date) - new Date(a.date))
  .slice(0, 3);

const trophyResults = results
  .filter((result) => result.showInTrophyCabinet)
  .slice(0, 3);
---

<BaseLayout title="Accueil | Blue Vault">
  <section class="hero">
    <p class="eyebrow">Palmarès esportif</p>
    <h1>Blue Vault</h1>

    <p>
      Site vitrine non officiel pour afficher les titres, podiums, résultats
      et joueurs de la structure Karmine Corp.
    </p>

    <div class="stats">
      <div>
        <strong>{results.length}</strong>
        <span>résultats renseignés</span>
      </div>

      <div>
        <strong>{trophyResults.length}</strong>
        <span>trophées affichés</span>
      </div>

      <div>
        <strong>{players.length}</strong>
        <span>joueurs renseignés</span>
      </div>
    </div>

    <div class="actions">
      <a href="/palmares">Voir le palmarès</a>
      <a href="/results">Tous les résultats</a>
    </div>
  </section>

  <section class="birthday-box" id="birthday-box" hidden>
    <h2>Anniversaires du jour</h2>
    <p id="birthday-content"></p>
  </section>

  <section>
    <h2>Derniers résultats</h2>

    <div class="grid">
      {latestResults.map((result) => (
        <article class="card">
          <h3>{result.resultTitle}</h3>
          <p>{result.game} — {result.competition}</p>
          <p>{result.placementLabel} — {result.date}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <h2>Trophées mis en avant</h2>

    <div class="grid">
      {trophyResults.map((result) => (
        <article class="card trophy">
          <h3>{result.resultTitle}</h3>
          <p>{result.game} — {result.competition}</p>
          <p>{result.placementLabel} — {result.date}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<script define:vars={{ players }}>
  const birthdayBox = document.querySelector("#birthday-box");
  const birthdayContent = document.querySelector("#birthday-content");

  if (birthdayBox && birthdayContent) {
    const today = new Date();

    const todayMonth = String(today.getMonth() + 1).padStart(2, "0");
    const todayDay = String(today.getDate()).padStart(2, "0");

    const birthdayPlayers = players.filter((player) => {
      if (!player.birthDate) {
        return false;
      }

      const status = String(player.status || "").trim().toLowerCase();

      if (status !== "active") {
        return false;
      }

      const [, month, day] = player.birthDate.split("-");

      return month === todayMonth && day === todayDay;
    });

    if (birthdayPlayers.length > 0) {
      const names = birthdayPlayers
        .map((player) => player.nickname)
        .join(", ");

      birthdayContent.textContent =
        birthdayPlayers.length === 1
          ? `Aujourd’hui, c’est l’anniversaire de ${names}.`
          : `Aujourd’hui, c’est l’anniversaire de ${names}.`;

      birthdayBox.hidden = false;
    }
  }
</script>

<style>
  .hero {
    padding: 64px 0;
  }

  .eyebrow {
    color: #60a5fa;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 13px;
    font-weight: bold;
  }

  h1 {
    font-size: 56px;
    margin: 12px 0;
  }

  h2 {
    margin-top: 56px;
  }

  .hero p {
    max-width: 650px;
    color: #cbd5e1;
    font-size: 18px;
    line-height: 1.6;
  }

  .stats {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin: 32px 0;
  }

  .stats div {
    min-width: 180px;
    padding: 18px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .stats strong {
    display: block;
    font-size: 32px;
  }

  .stats span {
    color: #cbd5e1;
  }

  .actions {
    display: flex;
    gap: 16px;
    margin-top: 32px;
  }

  .actions a {
    padding: 12px 18px;
    background: #2563eb;
    color: white;
    text-decoration: none;
    border-radius: 10px;
    font-weight: bold;
  }

  .actions a:last-child {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .birthday-box {
    margin: 32px 0;
    padding: 20px;
    border-radius: 16px;
    background: rgba(37, 99, 235, 0.18);
    border: 1px solid rgba(96, 165, 250, 0.3);
  }

  .birthday-box h2 {
    margin-top: 0;
  }

  .birthday-box p {
    color: #cbd5e1;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }

  .card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 20px;
    border-radius: 16px;
  }

  .card h3 {
    margin-top: 0;
  }

  .card p {
    color: #cbd5e1;
  }

  .trophy {
    background: rgba(37, 99, 235, 0.18);
  }

  @media (max-width: 700px) {
    h1 {
      font-size: 40px;
    }

    .actions {
      flex-direction: column;
    }
  }
</style>